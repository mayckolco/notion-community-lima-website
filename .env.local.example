# ─── Notion API ─────────────────────────────────────────────────────────────
# required — get from notion.so/profile/integrations
NOTION_TOKEN=secret_xxx
DB_SLOTS_ID=your-slots-database-id-here
# alias accepted by the app if DB_SLOTS_ID is unset:
DB_SESSIONS_ID=your-slots-database-id-here
DB_SPEAKERS_ID=your-speakers-database-id-here
DB_BOOTCAMP_DATES_ID=9e574cb31d8b4cf5a0d49bea50cfab22
DB_BOOTCAMP_REGISTROS_ID=686f7d1078614a009caa15c9c8acf2a8

# ─── Email verification (Resend) ─────────────────────────────────────────────
# required — get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# required — "From" address (domain must be verified in Resend)
# For testing without domain: use "onboarding@resend.dev"
RESEND_FROM_EMAIL=Claude Perú <noreply@yourdomain.com>
# optional — Resend Audience ID for newsletter subscribers (resend.com/audiences)
RESEND_AUDIENCE_ID=
# required — generate with: openssl rand -hex 32
EMAIL_VERIFICATION_SECRET=

# ─── URLs ────────────────────────────────────────────────────────────────────
# required — your production domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ─── Analytics ───────────────────────────────────────────────────────────────
# optional — Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# get from analytics.google.com → Admin → Data Streams → your web stream
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Cron security ───────────────────────────────────────────────────────────
# required — generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Luma (optional) ─────────────────────────────────────────────────────────
LUMA_API_KEY=
LUMA_CALENDAR_ID=
