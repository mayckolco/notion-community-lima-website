# ─── Notion API ─────────────────────────────────────────────────────────────
# required : get from notion.so/profile/integrations
NOTION_TOKEN=secret_xxx
DB_SLOTS_ID=your-slots-database-id-here
# optional legacy alias for DB_SLOTS_ID (older AIFF / speakers deployments)
# DB_SESSIONS_ID=
DB_SPEAKERS_ID=your-speakers-database-id-here
DB_COMUNIDAD_ID=your-comunidad-database-id-here
# optional : Notion database for community-submitted projects
DB_PROYECTOS_ID=
# Bootcamp: fechas en Notion (inscripciones se resuelven vía relación Persona)
DB_BOOTCAMP_DATES_ID=39d2acb3e8858025a599e6bb30fb65e1
# optional override : solo si Persona apunta a otra DB distinta
# DB_BOOTCAMP_REGISTROS_ID=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# required : get from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# required : "From" address (domain must be verified in Resend)
RESEND_FROM_EMAIL=Notion Community Lima <hola@yourdomain.com>
# optional : Resend Audience ID for newsletter subscribers (resend.com/audiences)
RESEND_AUDIENCE_ID=
# required : generate with: openssl rand -hex 32
EMAIL_VERIFICATION_SECRET=

# ─── URLs ────────────────────────────────────────────────────────────────────
# required : your production domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://notion.mayckolco.com

# ─── Analytics ───────────────────────────────────────────────────────────────
# optional : Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-1D2VSCG9LR
# optional : GA4 Admin API (solo local, para pnpm ga4:setup / ga4:check / ga4:consolidate)
GA4_PROPERTY_ID=545530988
GA4_SERVICE_ACCOUNT_PATH=.secrets/ga4-notion-lima.json

# ─── Cron security ───────────────────────────────────────────────────────────
# required : generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Luma (optional) ─────────────────────────────────────────────────────────
LUMA_API_KEY=
LUMA_CALENDAR_ID=
